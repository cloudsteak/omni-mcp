# Runtime
OMNI_MCP_ENVIRONMENT=development
OMNI_MCP_LOG_LEVEL=INFO

# Security limits
OMNI_MCP_OUTBOUND_HTTP_TIMEOUT_SECONDS=8
OMNI_MCP_MAX_HTTP_RESPONSE_BYTES=500000

# If set, only these hosts are allowed for outbound HTTP calls (http.fetch_text + HTTP-based LLM providers)
# Example: ["api.openai.com","api.anthropic.com","us-central1-aiplatform.googleapis.com"]
OMNI_MCP_ALLOWED_OUTBOUND_HOSTS=[]

# General LLM runtime defaults
OMNI_MCP_LLM_PROVIDER=openai
OMNI_MCP_LLM_MODEL=gpt-4.1-mini
OMNI_MCP_LLM_TEMPERATURE=0.2
OMNI_MCP_LLM_MAX_OUTPUT_TOKENS=800
OMNI_MCP_LLM_TIMEOUT_SECONDS=30

# OpenAI API
OMNI_MCP_LLM_OPENAI_API_KEY=
OMNI_MCP_LLM_OPENAI_BASE_URL=https://api.openai.com/v1/responses

# Anthropic API
OMNI_MCP_LLM_ANTHROPIC_API_KEY=
OMNI_MCP_LLM_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
OMNI_MCP_LLM_ANTHROPIC_VERSION=2023-06-01

# Azure Foundry / Azure OpenAI deployment endpoint
OMNI_MCP_LLM_AZURE_FOUNDRY_API_KEY=
OMNI_MCP_LLM_AZURE_FOUNDRY_ENDPOINT=
OMNI_MCP_LLM_AZURE_FOUNDRY_DEPLOYMENT=
OMNI_MCP_LLM_AZURE_FOUNDRY_API_VERSION=2024-10-21

# Google Vertex AI
OMNI_MCP_LLM_VERTEX_PROJECT_ID=
OMNI_MCP_LLM_VERTEX_LOCATION=us-central1
OMNI_MCP_LLM_VERTEX_MODEL=gemini-1.5-pro
OMNI_MCP_LLM_VERTEX_SERVICE_ACCOUNT_FILE=
OMNI_MCP_LLM_VERTEX_BEARER_TOKEN=

# AWS Bedrock
OMNI_MCP_LLM_BEDROCK_REGION=
OMNI_MCP_LLM_BEDROCK_MODEL_ID=

# Built-in skill toggles
OMNI_MCP_ENABLE_HTTP_SKILL=true
OMNI_MCP_ENABLE_FILE_READ_SKILL=true
OMNI_MCP_ENABLE_TIME_SKILL=true
OMNI_MCP_ENABLE_JSON_SKILL=true
OMNI_MCP_ENABLE_LLM_SKILL=true
