# Runtime
OMNI_MCP_ENVIRONMENT=development
OMNI_MCP_LOG_LEVEL=INFO

# Storage (PostgreSQL recommended)
OMNI_MCP_DATABASE_URL=postgresql+psycopg://omni_mcp:omni_mcp@localhost:5432/omni_mcp
OMNI_MCP_AUTO_CREATE_SCHEMA=true

# OpenAI (required for digest generation)
OMNI_MCP_OPENAI_API_KEY=
OMNI_MCP_OPENAI_MODEL=gpt-4.1-mini

# Tenant policy bounds
OMNI_MCP_MIN_POLL_INTERVAL_HOURS=2
OMNI_MCP_MAX_POLL_INTERVAL_HOURS=24
OMNI_MCP_MIN_RETENTION_DAYS=7
OMNI_MCP_MAX_RETENTION_DAYS=30

# Security limits
OMNI_MCP_OUTBOUND_HTTP_TIMEOUT_SECONDS=8
OMNI_MCP_MAX_HTTP_RESPONSE_BYTES=500000

# Example: ["feeds.bbci.co.uk","rss.nytimes.com"]
OMNI_MCP_ALLOWED_OUTBOUND_HOSTS=[]

# Optional shared secret for client integrations
OMNI_MCP_CLIENT_AUTH_SHARED_SECRET=
OMNI_MCP_SLACK_SIGNING_SECRET=

# Skill toggles
OMNI_MCP_ENABLE_HTTP_SKILL=true
OMNI_MCP_ENABLE_FILE_READ_SKILL=true
OMNI_MCP_ENABLE_TIME_SKILL=true
OMNI_MCP_ENABLE_JSON_SKILL=true
OMNI_MCP_ENABLE_RSS_DIGEST_SKILLS=true
