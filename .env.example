# Runtime
OMNI_MCP_ENVIRONMENT=development
OMNI_MCP_LOG_LEVEL=INFO

# Security limits
OMNI_MCP_OUTBOUND_HTTP_TIMEOUT_SECONDS=8
OMNI_MCP_MAX_HTTP_RESPONSE_BYTES=500000

# Comma-separated list interpreted by pydantic as JSON list when set explicitly.
# Example: ["example.com","api.github.com"]
OMNI_MCP_ALLOWED_OUTBOUND_HOSTS=[]

# Optional shared secret for client integrations
OMNI_MCP_CLIENT_AUTH_SHARED_SECRET=
OMNI_MCP_SLACK_SIGNING_SECRET=

# Skill toggles
OMNI_MCP_ENABLE_HTTP_SKILL=true
OMNI_MCP_ENABLE_FILE_READ_SKILL=true
OMNI_MCP_ENABLE_TIME_SKILL=true
OMNI_MCP_ENABLE_JSON_SKILL=true
